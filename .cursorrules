# ═══════════════════════════════════════════════════════════
# SECTION 11 — DOCKER COMPOSE FILES
# ═══════════════════════════════════════════════════════════

## docker-compose.yml — development (local machine)

```yaml
version: "3.9"

services:
  backend:
    build: ./backend
    ports:
      - "8000:8000"
    env_file: .env
    volumes:
      - ./backend:/app
      - ./data:/app/data
    depends_on: [redis, ollama]
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload

  worker:
    build: ./backend
    env_file: .env
    volumes:
      - ./data:/app/data
    depends_on: [redis, ollama]
    command: celery -A tasks.celery_app worker --loglevel=info --concurrency=2

  frontend:
    build: ./frontend
    ports:
      - "3000:3000"
    volumes:
      - ./frontend/src:/app/src
    environment:
      - VITE_API_URL=http://localhost:8000

  ollama:
    image: ollama/ollama:latest
    ports:
      - "127.0.0.1:11434:11434"   # CRITICAL: localhost only
    volumes:
      - ollama_data:/root/.ollama
    environment:
      - OLLAMA_HOST=127.0.0.1
    deploy:
      resources:
        limits:
          memory: 6G

  redis:
    image: redis:7.2-alpine
    ports:
      - "127.0.0.1:6379:6379"    # localhost only

volumes:
  ollama_data:
```

## docker-compose.demo.yml — prototype/demo (Oracle Cloud VM or ngrok)

```yaml
version: "3.9"

services:
  nginx:
    build: ./nginx
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./ssl:/etc/ssl/arqive:ro
    depends_on: [backend, frontend]
    restart: always

  backend:
    build: ./backend
    env_file: .env.demo
    volumes:
      - ./data:/app/data
    depends_on: [redis, ollama]
    restart: always
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 1

  worker:
    build: ./backend
    env_file: .env.demo
    volumes:
      - ./data:/app/data
    depends_on: [redis]
    restart: always
    command: celery -A tasks.celery_app worker --loglevel=info --concurrency=2

  frontend:
    build:
      context: ./frontend
      target: production
    restart: always

  ollama:
    image: ollama/ollama:latest
    volumes:
      - ollama_data:/root/.ollama
    environment:
      - OLLAMA_HOST=127.0.0.1
    restart: always
    network_mode: host            # localhost binding on the VM

  redis:
    image: redis:7.2-alpine
    restart: always
    command: redis-server --bind 127.0.0.1

volumes:
  ollama_data:
```

## docker-compose.prod.yml — production (client's server)

```yaml
version: "3.9"

services:
  nginx:
    build: ./nginx
    ports:
      - "80:80"
      - "443:443"
    depends_on: [backend, frontend]
    restart: always

  backend:
    build: ./backend
    env_file: .env.prod
    volumes:
      - ./data:/app/data
    depends_on: [db, redis, ollama]
    restart: always
    command: uvicorn app.main:app --host 0.0.0.0 --port 8000 --workers 2

  worker:
    build: ./backend
    env_file: .env.prod
    volumes:
      - ./data:/app/data
    depends_on: [db, redis]
    restart: always
    command: celery -A tasks.celery_app worker --loglevel=info --concurrency=4

  frontend:
    build:
      context: ./frontend
      target: production
    restart: always

  db:
    image: postgres:16-alpine
    volumes:
      - postgres_data:/var/lib/postgresql/data
    restart: always
    environment:
      POSTGRES_DB: arqive
      POSTGRES_USER: arqive
      POSTGRES_PASSWORD: ${DB_PASSWORD}
    # Port NOT exposed — internal network only

  ollama:
    image: ollama/ollama:latest
    volumes:
      - ollama_data:/root/.ollama
    environment:
      - OLLAMA_HOST=127.0.0.1
    restart: always
    network_mode: host

  redis:
    image: redis:7.2-alpine
    volumes:
      - redis_data:/data
    restart: always
    command: redis-server --bind 127.0.0.1 --save 60 1

volumes:
  postgres_data:
  ollama_data:
  redis_data:
```

## nginx/nginx.conf — critical SSE config

```nginx
# SSE streaming requires these — without them tokens buffer and
# the user sees nothing until the full response is complete
location /api/query/stream {
    proxy_pass http://backend:8000;
    proxy_buffering off;
    proxy_cache off;
    proxy_set_header X-Accel-Buffering no;
    proxy_read_timeout 180s;
    proxy_set_header Connection '';
    proxy_http_version 1.1;
    chunked_transfer_encoding on;
}
```

