# ── Application ─────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-min-32-chars-random
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Database ────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/arqive_dev.db
# DB_PASSWORD=                     # prod only

# ── ChromaDB ────────────────────────────────────────────────
CHROMA_PERSIST_PATH=./data/chromadb

# ── Ollama (URL hardcoded in code — these for health checks only)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT=120

# ── Embeddings ──────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_CACHE_PATH=./data/models

# ── Redis / Celery ──────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Document storage ────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/documents

# ── JWT ─────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── License ─────────────────────────────────────────────────
ARQIVE_LICENSE_KEY=dev-unlimited

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=pretty

# ── Demo mode ───────────────────────────────────────────────
DEMO_MODE=false
DEMO_RESET_HOURS=24
